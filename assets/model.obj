# cube.obj (unit cube centered at origin, size 2)
# positions
v -1 -1 -1
v  1 -1 -1
v  1  1 -1
v -1  1 -1
v -1 -1  1
v  1 -1  1
v  1  1  1
v -1  1  1

# uvs (per face)
vt 0 0
vt 1 0
vt 1 1
vt 0 1

# normals
vn  0  0 -1
vn  0  0  1
vn -1  0  0
vn  1  0  0
vn  0 -1  0
vn  0  1  0

# faces (each face uses the same 4 uvs and one normal)
# -Z
f 1/1/1 2/2/1 3/3/1 4/4/1
# +Z
f 5/1/2 8/4/2 7/3/2 6/2/2
# -X
f 1/1/3 4/4/3 8/3/3 5/2/3
# +X
f 2/1/4 6/2/4 7/3/4 3/4/4
# -Y
f 1/1/5 5/4/5 6/3/5 2/2/5
# +Y
f 4/1/6 3/2/6 7/3/6 8/4/6